<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ITS launchd template — copy this file, rename to <label>.plist,
  fill in the __PLACEHOLDERS__, then `install.sh load <label>`.

  Placeholders:
    __LABEL__            reverse-DNS label, e.g. org.solutionsmith.its.watchdog
                         (build phase: org.solutionsmith.its.*
                          post-handover: com.evergreenrenewables.its.*)
    __ITS_HOME__         left as-is; install.sh substitutes $HOME/its at install time
    __SCRIPT_PATH__      relative path from $ITS_HOME, e.g. scripts/watchdog.py
    __SCRIPT_BASENAME__  basename without extension, used for log filenames

  Pick ONE schedule block (see comments below) and delete the others.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>__LABEL__</string>

    <key>ProgramArguments</key>
    <array>
        <string>__ITS_HOME__/.venv/bin/python</string>
        <string>__ITS_HOME__/__SCRIPT_PATH__</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__ITS_HOME__</string>

    <key>StandardOutPath</key>
    <string>__ITS_HOME__/logs/launchd/__SCRIPT_BASENAME__.out.log</string>

    <key>StandardErrorPath</key>
    <string>__ITS_HOME__/logs/launchd/__SCRIPT_BASENAME__.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <!-- ============================================================ -->
    <!-- SCHEDULE: pick ONE of the three patterns below, delete others -->
    <!-- ============================================================ -->

    <!-- Pattern A — daily at a fixed time (watchdog, weekly summary): -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Pattern B — weekly (e.g. Fridays at 4 PM); Weekday: 0=Sun..6=Sat
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>5</integer>
        <key>Hour</key>
        <integer>16</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    -->

    <!-- Pattern C — recurring interval in seconds (email triage reclassify, hourly):
    <key>StartInterval</key>
    <integer>3600</integer>
    -->

    <key>RunAtLoad</key>
    <false/>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
