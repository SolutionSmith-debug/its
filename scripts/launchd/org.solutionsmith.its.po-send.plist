<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Purchase-Order SEND poll daemon (PO S5b, Aug-7 delivery program WS1). The send half of
  the External Send Gate two-process model for the VENDOR audience: discovers approved
  PO_Pending_Review rows (Send Now / Approve for Scheduled Send), runs the F22 approval-
  attestation gate against the ITS — Purchase Orders workspace (§46/D11), and dispatches
  each to po_materials.po_send.send_one_row (→ the shared weekly_send engine → Graph send
  from procurement@). AI-FREE (anthropic / anthropic_client AST-forbidden in
  tests/test_capability_gating.py SEND_SCRIPTS); the generation side (po-poll) is a
  SEPARATE process with zero send capability. Recipient resolved at send time from
  ITS_Vendors by Vendor Key. Gated OFF by po_materials.po_send.polling_enabled
  (scripts/migrations/seed_po_materials_config.py seeds it false).

  Install:
    scripts/launchd/install.sh load org.solutionsmith.its.po-send

  StartInterval is PARAMETERIZED (install.sh __POLL_INTERVAL_SECONDS__): resolution is
  [interval] arg > ITS_Config po_materials.po_send.poll_interval_seconds > default 900s
  (15 min, matching weekly-send / progress-send — an approval poller, not a fast puller).
  The resolved value is BAKED into the installed plist, so a later change needs a re-load.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.solutionsmith.its.po-send</string>

    <key>ProgramArguments</key>
    <array>
        <string>__ITS_HOME__/.venv/bin/python</string>
        <string>-m</string>
        <string>po_materials.po_send_poll</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__ITS_HOME__</string>

    <key>StandardOutPath</key>
    <string>__ITS_HOME__/logs/launchd/po_send.out.log</string>

    <key>StandardErrorPath</key>
    <string>__ITS_HOME__/logs/launchd/po_send.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <key>StartInterval</key>
    <integer>__POLL_INTERVAL_SECONDS__</integer>

    <!-- A2 (single-host resilience): RunAtLoad=true so this interval daemon RESUMES
         immediately when launchd loads the agent after a reboot/OS-update, then
         StartInterval re-fires on cadence. KeepAlive is intentionally absent: ITS daemons
         are one-shot-per-fire, so KeepAlive=true would restart on exit and destroy the
         interval cadence. -->
    <key>RunAtLoad</key>
    <true/>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
