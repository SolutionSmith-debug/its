<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Field-Ops job up-sync daemon (P2.5 Slice 5). Pulls dirty portal-created jobs from
  the Cloudflare Worker (GET /api/internal/fieldops/pending-jobs, bearer = the SEPARATE
  field-ops token) and mirrors each UP into BOTH ITS-owned Active-Jobs Smartsheets
  (find-or-create by "Portal Job Key"), per-sheet mark-mirrored. AI-free + customer-send-free
  (External Send Gate, FM Invariant 1; enrolled in tests/test_capability_gating.py
  GATED_SCRIPTS) — the Smartsheet WRITE is the intended SoR-mirror capability, and the HTTP
  egress to OUR Worker goes through the F02-allowlisted shared.portal_client. Fail-closed on
  missing creds. Gated OFF by field_ops.fieldops_sync.sync_enabled until cutover.

  Install:
    scripts/launchd/install.sh load org.solutionsmith.its.fieldops-sync

  StartInterval is hardcoded to 300s (5 min) — distinct from portal-poll (60s) /
  weekly-send (900s) so the daemons stagger. (Not ITS_Config-driven: this plist carries no
  poll-interval placeholder, so install.sh only substitutes the ITS home path;
  parameterizing the cadence via ITS_Config is a tidy follow-up.)

  See field_ops/README.md for the operator runbook.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.solutionsmith.its.fieldops-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>__ITS_HOME__/.venv/bin/python</string>
        <string>-m</string>
        <string>field_ops.fieldops_sync</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__ITS_HOME__</string>

    <key>StandardOutPath</key>
    <string>__ITS_HOME__/logs/launchd/fieldops_sync.out.log</string>

    <key>StandardErrorPath</key>
    <string>__ITS_HOME__/logs/launchd/fieldops_sync.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <key>StartInterval</key>
    <integer>300</integer>

    <!-- A2 (single-host resilience): RunAtLoad=true so this interval daemon RESUMES
         immediately when launchd loads the agent after a reboot/OS-update, then
         StartInterval re-fires on cadence. KeepAlive is intentionally absent: ITS daemons
         are one-shot-per-fire, so KeepAlive=true would restart on exit and destroy the
         interval cadence. -->
    <key>RunAtLoad</key>
    <true/>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
