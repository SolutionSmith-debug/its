<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Outbound-RFQ generation daemon (ADR-0004 R2, RFQ/estimate sub-lane of
  po_materials). The Mac generation half of the RFQ lane: drains composed RFQs
  from the Cloudflare Worker queue (GET /api/po/rfqs/internal/pending, bearer =
  the SEPARATE RFQ token tier — ADR-0004 decision 4 privilege separation),
  rfq:v1 HMAC-verifies each row (recompute-from-fields, the po:v1 pattern),
  renders one PRICE-FREE RFQ PDF per vendor in the signed fan-out list
  (ITS_Vendors SoR snapshot, read-only), files to Box
  (job → "Purchase Orders" → "RFQs"), writes the RFQ_Log (rfq, vendor) row +
  the RFQ_Pending_Review row (Workstream 'po_materials_rfq' — the distinct
  send-lane tag), posts mark-filed once per rfq, and mirrors review-sheet SENT
  stamps back via status-sync. AI-free (cloud AND local) + customer-send-free
  (External Send Gate, FM Invariant 1; enrolled in
  tests/test_capability_gating.py GATED_SCRIPTS — the send half is PR-D's
  rfq_send). Fail-closed on missing creds. Gated OFF by
  po_materials.rfq_poll.polling_enabled
  (scripts/migrations/seed_rfq_config.py seeds it false).

  Install:
    scripts/launchd/install.sh load org.solutionsmith.its.rfq-poll

  StartInterval is PARAMETERIZED (install.sh __POLL_INTERVAL_SECONDS__): resolution is
  [interval] arg > ITS_Config po_materials.rfq_poll.poll_interval_seconds >
  default 120s. Default 120s staggers off portal-poll (60s) and po-poll (90s); the
  resolved value is BAKED into the installed plist, so a later change needs a re-load.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.solutionsmith.its.rfq-poll</string>

    <key>ProgramArguments</key>
    <array>
        <string>__ITS_HOME__/.venv/bin/python</string>
        <string>-m</string>
        <string>po_materials.rfq_poll</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__ITS_HOME__</string>

    <key>StandardOutPath</key>
    <string>__ITS_HOME__/logs/launchd/rfq_poll.out.log</string>

    <key>StandardErrorPath</key>
    <string>__ITS_HOME__/logs/launchd/rfq_poll.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <key>StartInterval</key>
    <integer>__POLL_INTERVAL_SECONDS__</integer>

    <!-- A2 (single-host resilience): RunAtLoad=true so this interval daemon RESUMES
         immediately when launchd loads the agent after a reboot/OS-update, then
         StartInterval re-fires on cadence. KeepAlive is intentionally absent: ITS daemons
         are one-shot-per-fire, so KeepAlive=true would restart on exit and destroy the
         interval cadence. -->
    <key>RunAtLoad</key>
    <true/>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
