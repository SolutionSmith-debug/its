# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# ITS-specific
logs/*.log
logs/**/*.log
*.local.json
.env
.env.*

# Watchdog last-run markers (scripts/watchdog.py write_last_run_marker)
.watchdog/

# Alert-routing dedupe state file (shared/alert_dedupe.py)
state/

# Credentials must NEVER be committed.
# All secrets live in macOS Keychain — see shared/keychain.py.
*_secret*
*credentials*.json
*.token
*.pem
*.key

# Defensive — some SDKs cache HTTP responses to a local .cache/ dir.
# boxsdk 3.x does not, but the pattern guards against future deps that do.
.cache/
