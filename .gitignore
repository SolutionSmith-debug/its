# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Local render output of scripts/generate_form_archive.py (the publish daemon's archive
# step writes here on every cycle, even in --upload mode; the canonical copy is in Box).
/form_archive_out/

# ITS-specific
logs/*.log
logs/**/*.log
*.local.json
.env
.env.*

# Watchdog last-run markers (scripts/watchdog.py write_last_run_marker)
.watchdog/

# Alert-routing dedupe state file (shared/alert_dedupe.py)
state/

# Credentials must NEVER be committed.
# All secrets live in macOS Keychain — see shared/keychain.py.
*_secret*
*credentials*.json
*.token
*.pem
*.key

# Defensive — some SDKs cache HTTP responses to a local .cache/ dir.
# boxsdk 3.x does not, but the pattern guards against future deps that do.
.cache/

# Defensive — git worktrees for parallel CC sessions live as SIBLINGS of this
# repo (~/its-<task>), never nested inside it (see docs/operations/worktree_discipline.md).
# Sibling worktrees are outside the repo root, so git never sees them — this entry is
# a guard against the one accident that would matter: a worktree mistakenly created at
# the repo root (e.g. `git worktree add its-temp` without `../`), which would otherwise
# show as an untracked dir and could be staged or scanned by repo-relative tooling.
# No legitimate top-level dir is named its-*, so this is zero-false-positive.
/its-*/
